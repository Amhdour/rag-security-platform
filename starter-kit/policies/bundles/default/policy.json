{
  "global": {
    "kill_switch": false,
    "fallback_to_rag": true,
    "default_risk_tier": "medium"
  },
  "risk_tiers": {
    "low": {
      "max_retrieval_top_k": 8,
      "tools_enabled": true
    },
    "medium": {
      "max_retrieval_top_k": 5,
      "tools_enabled": true
    },
    "high": {
      "max_retrieval_top_k": 2,
      "tools_enabled": false
    }
  },
  "retrieval": {
    "allowed_tenants": [
      "tenant-a",
      "tenant-b"
    ],
    "tenant_allowed_sources": {
      "tenant-a": [
        "kb-main",
        "kb-faq"
      ],
      "tenant-b": [
        "kb-main-b"
      ]
    },
    "require_trust_metadata": true,
    "require_provenance": true,
    "allowed_trust_domains": [
      "internal"
    ]
  },
  "tools": {
    "allowed_tools": [
      "ticket_lookup",
      "account_update"
    ],
    "forbidden_tools": [
      "payments_export"
    ],
    "confirmation_required_tools": [
      "account_update"
    ],
    "forbidden_fields_per_tool": {
      "ticket_lookup": [
        "ssn"
      ],
      "account_update": [
        "raw_password"
      ]
    },
    "rate_limits_per_tool": {
      "ticket_lookup": 20,
      "account_update": 5
    }
  },
  "overrides": {
    "production": {
      "global": {
        "default_risk_tier": "high"
      },
      "tools": {
        "forbidden_tools": [
          "payments_export",
          "account_update"
        ]
      }
    }
  },
  "integrations": {
    "allowed_integrations": [
      "model_provider.default",
      "retrieval_backend.default",
      "tool_endpoint.ticket_lookup",
      "tool_endpoint.account_update",
      "mcp_server.support_mcp",
      "storage_output.audit_jsonl",
      "webhook.outbound_support"
    ],
    "tenant_allowed_integrations": {
      "tenant-a": [
        "model_provider.default",
        "retrieval_backend.default",
        "tool_endpoint.ticket_lookup",
        "tool_endpoint.account_update",
        "mcp_server.support_mcp",
        "storage_output.audit_jsonl",
        "webhook.outbound_support"
      ],
      "tenant-b": [
        "model_provider.default",
        "retrieval_backend.default",
        "tool_endpoint.ticket_lookup",
        "mcp_server.support_mcp",
        "storage_output.audit_jsonl",
        "webhook.outbound_support"
      ]
    },
    "allowed_data_classes": [
      "public",
      "internal_support",
      "metadata"
    ]
  }
}
